# Terraform state (SENSITIVE)
*.tfstate
*.tfstate.backup

# Terraform working directory
.terraform/

# Lock file (optional, but usually ignore for learning)
.terraform.lock.hcl

# Variable files (can contain secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc